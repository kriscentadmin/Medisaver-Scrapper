generator client {
  provider = "prisma-client-py"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Medicine {
  id            Int       @id @default(autoincrement())
  brand         String
  strength      String
  form          String
  variant       String
  canonicalName String    @unique
  approved      Boolean   @default(false)
  createdAt     DateTime  @default(now())
  approvedAt    DateTime?
  products      Product[]
}

model Product {
  id            Int      @id @default(autoincrement())
  medicineId    Int
  source        Source
  name          String
  pack          String?
  price         String?
  originalPrice String?
  discount      String?
  productUrl    String?
  endpoint      String?
  scrapedAt     DateTime @default(now())
  medicine      Medicine @relation(fields: [medicineId], references: [id], onDelete: Cascade)

  @@unique([medicineId, source])
}

model SearchRequest {
  id            Int          @id @default(autoincrement())
  brand         String
  strength      String
  form          String
  variant       String
  canonicalName String
  operatorName  String
  status        SearchStatus @default(PENDING)
  createdAt     DateTime     @default(now())

  @@unique([brand, strength, form, variant])
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
}

model Form {
  id   Int    @id @default(autoincrement())
  form String @unique
}

model Variant {
  id      Int    @id @default(autoincrement())
  variant String @unique
}

model ScraperState {
  id                  Int       @id
  lastIndex           Int       @default(0) @map("last_index")
  day                 String
  elapsedSecondsToday Float     @default(0) @map("elapsed_seconds_today")
  savedToday          Json      @map("saved_today")
  totalSavedToday     Int       @default(0) @map("total_saved_today")
  running             Boolean   @default(false)
  startedAt           DateTime? @map("started_at")
  finishedAt          DateTime? @map("finished_at")
  summaryJson         Json?     @map("summary_json")
  errorText           String?   @map("error_text")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@map("scraper_state")
}

enum Role {
  ADMIN
}

enum Source {
  NETMEDS
  PHARMEASY
  ONEMG
  TRUEMEDS
}

enum SearchStatus {
  PENDING
  APPROVED
  REJECTED
}
